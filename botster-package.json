{
  "name": "botster-workspaces",
  "version": "0.1.0",
  "kind": "plugin",
  "botster": ">=0.1.0",
  "description": "First-party Botster workspace records, session grouping, and surfaces.",
  "source": { "type": "path", "path": "." },
  "capabilities": [
    { "surface": "mcp" },
    { "surface": "plugin_db", "scope": "botster-workspaces" },
    { "surface": "surfaces" },
    { "surface": "filesystem", "scope": "workspace" }
  ],
  "configuration": {
    "groups": [
      {
        "id": "workspace_defaults",
        "label": "Workspace defaults"
      }
    ],
    "fields": [
      {
        "key": "archive_policy",
        "type": "select",
        "label": "Archive policy",
        "group": "workspace_defaults",
        "default": { "type": "select", "value": "mark_deleted" },
        "options": [
          { "value": "mark_deleted", "label": "Mark deleted" },
          { "value": "archive", "label": "Archive" }
        ]
      }
    ]
  },
  "surfaces": [
    {
      "id": "workspaces",
      "kind": "app",
      "title": "Workspaces",
      "description": "Descriptor-backed workspace package surface bound to workspace entity state.",
      "icon": "rectangle-group",
      "category": "workspace",
      "supports": ["render"]
    },
    {
      "id": "workspaces-settings",
      "kind": "settings",
      "title": "Workspaces Settings",
      "description": "Descriptor-backed workspace settings surface for package-level workspace defaults.",
      "icon": "cog-6-tooth",
      "category": "workspace",
      "supports": ["render"]
    }
  ],
  "navigation": [
    {
      "id": "workspaces",
      "label": "Workspaces",
      "icon": "rectangle-group",
      "description": "Open the workspace records surface.",
      "target": { "kind": "surface", "surface_id": "workspaces" }
    },
    {
      "id": "workspaces-settings",
      "label": "Workspaces Settings",
      "icon": "cog-6-tooth",
      "description": "Open workspace package defaults.",
      "target": { "kind": "surface", "surface_id": "workspaces-settings" }
    }
  ],
  "entrypoints": [
    { "runtime": "lua", "path": "plugin.lua", "bootstrap": false }
  ]
}
