#!/usr/bin/env ruby
# frozen_string_literal: true

require "json"
require "socket"

socket_path = ARGV.fetch(0) do
  warn "usage: script/hub_acceptance_smoke <botster-hub.sock> [workspace-name]"
  exit 1
end

workspace_name = ARGV[1] || "Acceptance Workspace"

def assert(condition, message)
  raise message unless condition
end

socket = UNIXSocket.new(socket_path)
socket.puts(JSON.generate({
  protocol: "botster-hub-daemon-v1",
  compatibility: {
    protocol: "botster-hub-daemon-v1",
    minimum_protocol_version: 1,
    required_features: %w[
      sessions
      terminal_streaming
      resize
      package_navigation
      plugin_surface_render
      plugin_surface_action
    ],
    # The locked hub used by this repository reports conformance fixture
    # revision 1; hub lifecycle fixtures use the same minimum for plugin
    # surface action/render coverage.
    minimum_conformance_fixture_revision: 1,
    client_name: "botster-workspaces-acceptance-smoke"
  }
}))
hello_line = socket.gets
raise "daemon closed before hello" unless hello_line
hello = JSON.parse(hello_line)
assert(hello["protocol"] == "botster-hub-daemon-v1", "daemon hello failed")

def request_raw(socket, payload)
  socket.puts(JSON.generate(payload))
  JSON.parse(socket.gets)
end

def request(socket, payload)
  response = request_raw(socket, payload)
  if response["error"]
    raise "daemon #{payload.fetch(:type)} failed: #{response["error"]}"
  end
  response
end

def call_tool(socket, name, arguments)
  response = request(socket, {
    type: "plugin_mcp_call_tool",
    name: name,
    arguments: arguments
  })
  assert(response["kind"] == "plugin_mcp_tool_result", "#{name} returned #{response["kind"]}")
  response.fetch("plugin_tool_result")
end

def collect_text(node, out = [])
  props = node["props"] || {}
  out << props["text"] if node["type"] == "text" && props["text"]
  out << props["title"] if node["type"] == "empty_state" && props["title"]
  out << props["label"] if node["type"] == "status_badge" && props["label"]
  Array(node["children"]).each { |child| collect_text(child, out) }
  (node["slots"] || {}).each_value do |children|
    Array(children).each { |child| collect_text(child, out) }
  end
  out
end

def collect_types(node, out = Hash.new(0))
  out[node["type"]] += 1 if node["type"]
  Array(node["children"]).each { |child| collect_types(child, out) }
  (node["slots"] || {}).each_value do |children|
    Array(children).each { |child| collect_types(child, out) }
  end
  out
end

def assert_primitives(surface, surface_id, expected)
  types = collect_types(surface)
  expected.each do |type|
    assert(types[type].positive?, "#{surface_id} rendered body missing #{type}")
  end
end

def assert_no_inert_interactions(node)
  props = node["props"] || {}
  %w[activation primary_action selection].each do |field|
    assert(!props.key?(field), "#{node["id"] || node["type"]} must not emit inert #{field}")
  end
  action = props["action"]
  assert(!action.is_a?(Hash) || !action.key?("payload"), "#{node["id"] || node["type"]} must not emit payload-bearing action")
  Array(node["children"]).each { |child| assert_no_inert_interactions(child) }
  (node["slots"] || {}).each_value do |children|
    Array(children).each { |child| assert_no_inert_interactions(child) }
  end
end

def collect_terminal_output(response)
  Array(response["events"]).filter_map do |event|
    event["data"] if event["type"] == "terminal_output"
  end.join
end

def render_surface(socket, surface_id)
  response = request(socket, {
    type: "plugin_surface_render",
    package_name: "botster-workspaces",
    surface_id: surface_id,
    payload: {}
  })
  assert(response["kind"] == "plugin_surface", "#{surface_id} did not return plugin surface")
  plugin_surface = response.fetch("plugin_surface")
  assert(plugin_surface.fetch("package_name") == "botster-workspaces", "#{surface_id} package identity mismatch")
  assert(plugin_surface.fetch("surface_id") == surface_id, "#{surface_id} surface identity mismatch")
  snapshot = plugin_surface["ui_tree_snapshot"]
  if snapshot
    assert(snapshot.fetch("package_name") == "botster-workspaces", "#{surface_id} snapshot package identity mismatch")
    assert(snapshot.fetch("surface_id") == surface_id, "#{surface_id} snapshot surface identity mismatch")
  end
  plugin_surface.fetch("body")
end

tools = request(socket, { type: "plugin_mcp_list_tools" })
tool_names = tools.fetch("plugin_tools").map { |tool| tool.fetch("name") }
%w[
  botster_workspaces.create
  botster_workspaces.list
  botster_workspaces.show
  botster_workspaces.update
  botster_workspaces.delete
  botster_workspaces.refresh_template_diagnostics
  botster_workspaces.spawn_default_session
  botster_workspaces.entity_snapshot
].each do |name|
  assert(tool_names.include?(name), "missing plugin MCP tool #{name}")
end

packages = request(socket, { type: "list_packages" })
assert(packages["kind"] == "packages", "daemon did not expose packages")
package = packages.fetch("packages").find { |candidate| candidate["package_name"] == "botster-workspaces" }
assert(package, "botster-workspaces package row missing")
surface_by_id = package.fetch("surfaces").to_h { |surface| [surface.fetch("id"), surface] }
assert(surface_by_id.dig("workspaces", "kind") == "app", "workspaces app descriptor missing")
assert(surface_by_id.dig("workspaces", "icon") == "rectangle-group", "workspaces app icon missing")
assert(surface_by_id.dig("workspaces-settings", "kind") == "settings", "workspaces settings descriptor missing")
assert(surface_by_id.dig("workspaces-settings", "icon") == "cog-6-tooth", "workspaces settings icon missing")
package.fetch("surfaces").each do |surface|
  %w[order priority pinned hidden placement sidebar_position sort].each do |field|
    assert(!surface.key?(field), "surface descriptor must not expose placement authority #{field}")
  end
end
route_by_id = package.fetch("routes").to_h { |route| [route.fetch("route_id"), route] }
assert(route_by_id.dig("surface:workspaces", "route_path") == "/packages/botster-workspaces/surfaces/workspaces", "workspaces route path missing")
assert(route_by_id.dig("surface:workspaces", "target", "kind") == "plugin_surface", "workspaces route target mismatch")
assert(route_by_id.dig("surface:workspaces-settings", "route_path") == "/packages/botster-workspaces/surfaces/workspaces-settings", "workspaces settings surface route path missing")
assert(route_by_id.dig("surface:workspaces-settings", "target", "kind") == "plugin_surface", "workspaces settings surface route target mismatch")
assert(route_by_id.dig("settings", "route_path") == "/packages/botster-workspaces/settings", "settings route path missing")
config = package.fetch("configuration")
assert(config.fetch("schema").fetch("fields").any? { |field| field["key"] == "archive_policy" }, "archive_policy schema missing")

navigation_response = request(socket, { type: "list_package_navigation" })
assert(navigation_response["kind"] == "package_navigation", "daemon did not expose package navigation registry")
navigation_entries = navigation_response.fetch("package_navigation").select { |entry| entry["package_name"] == "botster-workspaces" }
navigation_by_id = navigation_entries.to_h { |entry| [entry.fetch("item_id"), entry] }
{
  "workspaces" => "/packages/botster-workspaces/surfaces/workspaces",
  "workspaces-settings" => "/packages/botster-workspaces/surfaces/workspaces-settings"
}.each do |item_id, route_path|
  entry = navigation_by_id.fetch(item_id) { raise "missing Workspaces navigation entry #{item_id}" }
  assert(entry.fetch("route_id") == "surface:#{item_id}", "#{item_id} navigation route id mismatch")
  assert(entry.fetch("route_path") == route_path, "#{item_id} navigation route path mismatch")
  assert(entry.dig("target", "kind") == "plugin_surface", "#{item_id} navigation target kind mismatch")
  assert(entry.dig("target", "surface_id") == item_id, "#{item_id} navigation target surface mismatch")
  assert(entry.dig("source", "kind") == "surface", "#{item_id} navigation source kind mismatch")
  assert(entry.dig("source", "surface_id") == item_id, "#{item_id} navigation source surface mismatch")
  assert(entry["enabled"] == true, "#{item_id} navigation must be enabled")
  assert(entry["blocked"] == false, "#{item_id} navigation must not be blocked")
  assert(entry.fetch("diagnostics", []).empty?, "#{item_id} navigation diagnostics must be empty")
  %w[order priority pinned hidden placement sidebar_position sort].each do |field|
    assert(!entry.key?(field), "#{item_id} navigation must not expose placement authority #{field}")
  end
  surface = render_surface(socket, entry.dig("target", "surface_id"))
  assert(surface.is_a?(Hash) && surface["type"].is_a?(String), "#{item_id} navigation target did not render a UiNode surface")
  assert_no_inert_interactions(surface)
  text = collect_text(surface).join("\n")
  if item_id == "workspaces"
    assert_primitives(surface, item_id, %w[panel toolbar metric_grid section list])
  else
    assert_primitives(surface, item_id, %w[panel metric_grid section list])
  end
  if text.include?("No active workspaces")
    assert_primitives(surface, item_id, %w[empty_state])
  else
    assert_primitives(surface, item_id, %w[list_item status_badge])
  end
end

valid_config = request(socket, {
  type: "set_package_configuration",
  package_name: "botster-workspaces",
  values: {
    archive_policy: {
      type: "select",
      value: "archive"
    }
  }
})
assert(valid_config["kind"] == "packages", "valid package config set did not return package row")
reload = request(socket, {
  type: "reload_package",
  package_name: "botster-workspaces"
})
assert(%w[packages package_decision].include?(reload["kind"]), "package reload after config set failed")

invalid_config = request_raw(socket, {
  type: "set_package_configuration",
  package_name: "botster-workspaces",
  values: {
    archive_policy: {
      type: "select",
      value: "unsupported"
    }
  }
})
assert(invalid_config["error"], "invalid package config must fail")
assert(invalid_config["error"].to_s.include?("archive_policy"), "invalid package config error must name archive_policy")

templates = request(socket, { type: "list_session_templates" })
assert(templates["kind"] == "session_templates", "daemon did not expose session templates")
template = templates.fetch("session_templates", []).first
unless template
  create = call_tool(socket, "botster_workspaces.create", {
    name: workspace_name,
    purpose: "Acceptance smoke for package surfaces without session templates",
    local_repo_ref: {
      id: "repo_acceptance",
      display_name: "Acceptance repo",
      repo_capability_ref: "repo_capability_acceptance",
      default_branch: "main",
      relative_worktree_hint: "worktrees/acceptance"
    },
    spawn_target_ref: {
      target_id: "target_acceptance",
      label: "Acceptance target",
      kind: "agent",
      capability_ref: "spawn_target_acceptance"
    }
  })
  assert(create["ok"] == true || create.dig("error", "code") == "duplicate_active_name", "workspace create failed: #{create}")
  if create["ok"] == true
    assert(create.fetch("workspace").fetch("settings").fetch("archive_policy") == "archive", "package config did not seed workspace archive policy")
  end

  %w[workspaces workspaces-settings].each do |surface_id|
    surface = render_surface(socket, surface_id)
    assert_no_inert_interactions(surface)
    assert_primitives(surface, surface_id, %w[panel metric_grid section list list_item status_badge])
    text = collect_text(surface).join("\n")
    assert(text.include?(workspace_name), "#{surface_id} surface missing workspace name")
    assert(text.include?("Acceptance repo"), "#{surface_id} surface missing repo label")
    assert(text.include?("Acceptance target"), "#{surface_id} surface missing spawn target label")
  end

  puts "script/hub_acceptance_smoke: ok package_surface_config_only no_session_templates=true"
  exit 0
end
template_id = template.fetch("template_id")
target_id = template.fetch("target_id")

create = call_tool(socket, "botster_workspaces.create", {
  name: workspace_name,
  purpose: "Acceptance smoke for enabled plugin worker",
  local_repo_ref: {
    id: "repo_acceptance",
    display_name: "Acceptance repo",
    repo_capability_ref: "repo_capability_acceptance",
    default_branch: "main",
    relative_worktree_hint: "worktrees/acceptance"
  },
  spawn_target_ref: {
    target_id: target_id,
    label: "Acceptance template target",
    kind: "agent",
    capability_ref: "spawn_target_acceptance"
  },
  default_session_template_refs: [
    {
      template_id: template_id,
      label: "Acceptance template",
      role: "acceptance",
      group: "primary",
      selected: true
    }
  ]
})
existing = false
if create["ok"] == true
  workspace_id = create.fetch("workspace").fetch("id")
  assert(create.fetch("workspace").fetch("settings").fetch("archive_policy") == "archive", "package config did not seed workspace archive policy")
else
  assert(create.dig("error", "code") == "duplicate_active_name", "workspace create failed: #{create}")
  existing = true
  existing_list = call_tool(socket, "botster_workspaces.list", {})
  existing_row = existing_list.fetch("workspaces").find { |workspace| workspace["name"] == workspace_name }
  assert(existing_row, "duplicate workspace name was reported but no existing row was listed")
  workspace_id = existing_row.fetch("id")
end

update = call_tool(socket, "botster_workspaces.update", {
  id: workspace_id,
  patch: {
    session_group: {
      session_refs: [
        {
          session_uuid: "example-session-acceptance-1",
          role: "implement",
          spawned_from_template_id: template_id,
          status: "running"
        },
        {
          session_uuid: "example-session-acceptance-2",
          role: "verify",
          spawned_from_template_id: template_id,
          status: "queued"
        }
      ]
    }
  }
})
assert(update.fetch("entity").fetch("session_count") == 2, "session grouping did not update")

refresh = call_tool(socket, "botster_workspaces.refresh_template_diagnostics", {
  id: workspace_id
})
assert(refresh["ok"] == true, "template diagnostic refresh failed")
assert(refresh.fetch("workspace").fetch("default_session_template_refs").first.fetch("template_id") == template_id, "template reference was not preserved")

template_session_id = "wst#{Process.pid % 10_000}#{Time.now.to_i % 100_000}"
spawn_selection = call_tool(socket, "botster_workspaces.spawn_default_session", {
  id: workspace_id,
  session_id: template_session_id,
  prompt: "Acceptance smoke workspace context"
})
assert(spawn_selection["ok"] == true, "workspace template spawn selection failed")
assert(spawn_selection["hub_api"] == "spawn_session_template", "workspace did not select hub template spawn API")
daemon_request = spawn_selection.fetch("daemon_request")
assert(daemon_request.fetch("type") == "spawn_session_template", "workspace returned non-template spawn request")
assert(!daemon_request.key?("target_id"), "workspace must not echo hub-owned target_id into template spawn")
assert(!daemon_request.fetch("request").key?("cwd"), "workspace must not inject unproven cwd override")
assert(!daemon_request.fetch("request").key?("env"), "workspace must not inject unproven env override")
assert(!daemon_request.dig("request", "context").key?("metadata"), "workspace must not inject unproven metadata context")
spawn_response = request(socket, daemon_request.transform_keys(&:to_sym))
assert(spawn_response["kind"] == "spawned", "hub did not spawn from workspace-selected template")

attach_response = request(socket, {
  type: "attach",
  session_id: template_session_id,
  subscription_id: "workspaces-acceptance-smoke"
})
assert(attach_response["kind"] == "events", "template session attach returned #{attach_response["kind"]}")

observed = +""
deadline = Time.now + 5
while Time.now < deadline
  drain = request(socket, {
    type: "drain",
    session_id: template_session_id
  })
  assert(drain["kind"] == "events", "template session drain returned #{drain["kind"]}")
  observed << collect_terminal_output(drain)
  break if observed.include?("workspace-template-ready")

  sleep 0.03
end
assert(observed.include?("workspace-template-ready"), "template session output was not observed: #{observed.inspect}")

shutdown_template = request(socket, {
  type: "shutdown_session",
  session_id: template_session_id
})
assert(shutdown_template["kind"] == "events", "template session shutdown returned #{shutdown_template["kind"]}")

list = call_tool(socket, "botster_workspaces.list", {})
row = list.fetch("workspaces").find { |workspace| workspace["id"] == workspace_id }
assert(row, "created workspace missing from list")
assert(row["session_count"] == 2, "list row did not expose session count")
assert(row["default_session_template_count"] == 1, "list row did not expose template count")

show = call_tool(socket, "botster_workspaces.show", { id: workspace_id })
assert(show.fetch("workspace").fetch("session_group").fetch("session_refs").length == 2, "show did not preserve session refs")

snapshot = call_tool(socket, "botster_workspaces.entity_snapshot", {})
assert(snapshot["entity_family"] == "botster-workspaces.workspace", "snapshot family mismatch")
assert(snapshot.fetch("rows").any? { |snapshot_row| snapshot_row["id"] == workspace_id }, "snapshot missing workspace")

%w[workspaces workspaces-settings].each do |surface_id|
  surface = render_surface(socket, surface_id)
  assert_no_inert_interactions(surface)
  assert_primitives(surface, surface_id, %w[panel metric_grid section list list_item status_badge])
  assert_primitives(surface, surface_id, %w[toolbar]) if surface_id == "workspaces"
  text = collect_text(surface).join("\n")
  assert(text.include?(workspace_name), "#{surface_id} surface missing workspace name")
  assert(text.include?("2 sessions"), "#{surface_id} surface missing session count")
  assert(text.include?("Templates:"), "#{surface_id} surface missing template summary")
  assert(text.include?("Acceptance repo"), "#{surface_id} surface missing repo label")
  assert(text.include?("Acceptance template target"), "#{surface_id} surface missing spawn target label")
  assert(text.include?("Archive policy: Archive"), "#{surface_id} surface missing archive-policy content") if surface_id == "workspaces-settings"
end

puts "script/hub_acceptance_smoke: ok workspace_id=#{workspace_id} template_id=#{template_id} existing=#{existing}"
