      "id": "ws_product_refactor",
      "not_found_error": "workspace_not_found"
    },
    "update": {
      "allowed_fields": [
        "name",
        "purpose",
        "local_repo_ref",
        "spawn_target_ref",
        "default_session_template_id",
        "default_session_template_refs",
        "settings",
        "session_group.session_refs"
      ],
      "rejected_hub_owned_fields": [
        "process_state",
        "process_spawn_request",
        "pty_state",
        "pty_request",
        "raw_spawn_request",
        "spawn_command",
        "terminal_scrollback",
        "package_admission",
        "spawn_target_record",
        "session_manifest"
      ],
      "template_selection_path": "botster_workspaces.update.default_session_template_refs.selected",
      "surface_selection_action_descriptor": null
    },
    "refresh_template_diagnostics": {
      "hub_api": "resolve_session_template",
      "invalid_references_preserved": true
    },
    "spawn_default_session": {
      "hub_api": "spawn_session_template",
      "context_fields": [
        "workspace_id",
        "prompt",
        "ticket_id",
        "branch_name"
      ],
      "does_not_construct_raw_spawn": true
    },
    "delete": {
      "mode": "mark_deleted",
      "excluded_from_default_list": true,
      "does_not_delete": [
        "hub_sessions",
        "package_records",
        "spawn_targets",
        "repository_content",
        "host_filesystem_content"
      ]
